# App runtime
NODE_ENV="development"

# Logger
# LOG_LEVEL: error | warn | info | debug
LOG_LEVEL="debug"
# LOG_TO_FILE: console | file | both | auto
LOG_TO_FILE="both"

# Database
DATABASE_URL="mysql://root:password@localhost:3306/db"
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="db"

# JWT
JWT_SECRET_ACCESS_KEY="your_secret_key_access"
JWT_SECRET_REFRESH_KEY="your_secret_key_refresh"
JWT_ACCESS_TOKEN_EXPIRES_IN="15m"
JWT_REFRESH_TOKEN_EXPIRES_IN="1d"
