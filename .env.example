# App runtime
NODE_ENV="development"

# Logger
# LOG_LEVEL: error | warn | info | debug
LOG_LEVEL="debug"
# LOG_TO_FILE: console | file | both | auto
LOG_TO_FILE="both"

# Database
DATABASE_URL="mysql://root:password@localhost:3306/db"
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_USER="root"
DATABASE_PASSWORD="password"
DATABASE_NAME="db"
