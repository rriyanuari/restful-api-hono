generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Int         @id @default(autoincrement())
  uid        String      @unique(map: "User_uid_key") @default(uuid())
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  deleted_at DateTime?
  name       String      @db.VarChar(100)
  email      String      @unique(map: "User_email_key") @db.VarChar(255)
  password   String      @db.VarChar(255)
  userTokens UserToken[] // relation field
  userRoles   UserRole[] // relation field

  @@map("users")
}

model UserToken {
  id          Int       @id @default(autoincrement())
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  user        User      @relation(fields: [userId], references: [id])
  userId      Int       @map("user_id") // relation scalar field  (used in the `@relation` attribute above)
  value       String    @db.VarChar(255) @unique
  token_type  String    @db.VarChar(50)
  device_type String?   @db.VarChar(20)
  expires_at  DateTime

  @@unique([userId, device_type], name: "userId_device_type_key") // unique constraint for userId and device_type
  @@map("user_tokens")
}

model Permission {
  id  Int    @id @default(autoincrement())
  uid String @unique

  name        String  @unique
  code        String  @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Role {
  id  Int    @id @default(autoincrement())
  uid String @unique

  name        String  @unique
  code        String  @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  UserRole        UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}
